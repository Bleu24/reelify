# Supabase (public)
#
# Copy this file to `.env.local` and fill in values from the Supabase dashboard.
# Never commit real keys.

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Recommended for new apps (works anywhere `createClient()` expects a key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Legacy anon key (supported; optional if you use publishable keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase (server-only)
# Used for server-side operations. Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=""

# TikTok Login Kit (server-only)
# Create an app in TikTok Developer Portal and copy credentials here.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Must exactly match one of the redirect URIs registered in your TikTok app.
# For local dev:
#   http://localhost:3000/auth/tiktok/callback
TIKTOK_REDIRECT_URI="http://localhost:3000/auth/tiktok/callback"
